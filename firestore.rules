// ╔══════════════════════════════════════════════════════════════╗
// ║  AutoScrip — Firestore Security Rules (FIXED v2)            ║
// ║  Project: powerscript-pro-web                               ║
// ║  সমস্যা সমাধান:                                             ║
// ║  ✅ Public read — সবাই tools দেখতে পারবে                  ║
// ║  ✅ isAdmin() — autoscrip_admins থেকে role check           ║
// ║  ✅ Quota বাঁচাতে get() call কমানো হয়েছে                  ║
// ║  ✅ Tool CRUD — admin শুধু write করতে পারবে               ║
// ╚══════════════════════════════════════════════════════════════╝

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function uid()    { return request.auth.uid; }

    // ✅ FIXED: একটাই get() call — quota বাঁচে
    function getAdminDoc() {
      return get(/databases/$(database)/documents/autoscrip_admins/$(request.auth.uid));
    }
    function adminExists() {
      return isAuth() && exists(/databases/$(database)/documents/autoscrip_admins/$(request.auth.uid));
    }
    function isAdmin() {
      return adminExists() &&
        getAdminDoc().data.role == 'admin' &&
        getAdminDoc().data.active != false;
    }
    function isModerator() {
      return adminExists() &&
        getAdminDoc().data.role in ['admin','moderator'] &&
        getAdminDoc().data.active != false;
    }
    function isOwner(docUid) {
      return isAuth() && uid() == docUid;
    }

    // ── autoscrip_tools ────────────────────────────────────────
    // ✅ CRITICAL FIX: Public read — সবাই tools দেখতে পারবে
    // ✅ Write — শুধু moderator/admin
    // ✅ Stats (views/downloads/likes) — যেকোনো user update করতে পারবে
    match /autoscrip_tools/{toolId} {
      allow read: if true;  // সবাই পড়তে পারবে

      // Admin/Moderator full write access
      allow create: if isModerator();
      allow delete: if isAdmin();

      // Update: 2 rules — admin can update anything, any user can increment stats
      allow update: if isModerator();
      allow update: if isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['views','downloads','likes']);
      // Unauthenticated views increment (anonymous users)
      allow update: if !isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['views']);
    }

    // ── autoscrip_users ────────────────────────────────────────
    match /autoscrip_users/{userId} {
      allow read:   if isOwner(userId) || isModerator();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isModerator();
      allow delete: if isAdmin();
    }

    // ── autoscrip_admins ────────────────────────────────────────
    // নিজেকে নিজে admin বানানো নিষেধ
    match /autoscrip_admins/{adminId} {
      allow read:   if isOwner(adminId) || isAdmin();
      allow create: if isAdmin() && adminId != uid();
      allow update: if isAdmin() && adminId != uid();
      allow delete: if isAdmin() && adminId != uid();
    }

    // ── autoscrip_categories ────────────────────────────────────
    match /autoscrip_categories/{catId} {
      allow read:  if true;
      allow write: if isModerator();
    }

    // ── autoscrip_requests ────────────────────────────────────
    match /autoscrip_requests/{reqId} {
      allow create: if isAuth() && request.resource.data.submittedBy == uid();
      allow read:   if isAuth() && (resource.data.submittedBy == uid() || isModerator());
      allow update, delete: if isModerator();
    }

    // ── autoscrip_notifications ────────────────────────────────
    match /autoscrip_notifications/{notifId} {
      allow read:  if isModerator() ||
        (isAuth() && (
          !('targetUid' in resource.data) ||
          resource.data.targetUid == '' ||
          resource.data.targetUid == uid()
        ));
      allow write: if isModerator();
    }

    // ── autoscrip_comments ────────────────────────────────────
    match /autoscrip_comments/{commentId} {
      allow read: if true;
      allow create: if isAuth() &&
        request.resource.data.authorId == uid() &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 1000;
      allow update: if isAuth() && resource.data.authorId == uid() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['text','updatedAt']);
      allow delete: if isAuth() && resource.data.authorId == uid();
      allow update, delete: if isModerator();
    }

    // ── autoscrip_config ────────────────────────────────────────
    match /autoscrip_config/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── autoscrip_youtube ────────────────────────────────────────
    match /autoscrip_youtube/{docId} {
      allow read:  if true;
      allow write: if isModerator();
    }

    // ── autoscrip_subscribers ────────────────────────────────────
    match /autoscrip_subscribers/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── autoscrip_activity ────────────────────────────────────────
    match /autoscrip_activity/{docId} {
      allow read, write: if isAdmin();
    }

    // ── autoscrip_posts ────────────────────────────────────────────
    match /autoscrip_posts/{postId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.authorId == uid();
      allow update, delete: if (isAuth() && resource.data.authorId == uid()) || isModerator();
    }

    // ── autoscrip_scripts ────────────────────────────────────────
    match /autoscrip_scripts/{scriptId} {
      allow read: if isModerator() ||
        (isAuth() && resource.data.authorId == uid()) ||
        resource.data.public == true;
      allow create: if isAuth() && request.resource.data.authorId == uid();
      allow update, delete: if (isAuth() && resource.data.authorId == uid()) || isModerator();
    }

    // ── autoscrip_versions ────────────────────────────────────────
    match /autoscrip_versions/{verId} {
      allow read, write: if isModerator();
    }

    // ── autoscrip_chat ────────────────────────────────────────────
    match /autoscrip_chat/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.senderUid == uid() &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 500;
      allow delete: if isAdmin() || (isAuth() && resource.data.senderUid == uid());
    }

    // ── Default (catch-all) ────────────────────────────────────
    // শুধু admin সব collection access করতে পারবে
    match /{collection}/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
