// ╔══════════════════════════════════════════════════════════════════╗
// ║  AutoScrip — Firestore Security Rules (FIXED v3)                ║
// ║  Project: powerscript-pro-web                                    ║
// ║                                                                  ║
// ║  ✅ FIX 1: isAdmin() — email/uid OR admins collection check     ║
// ║  ✅ FIX 2: role: super_admin | admin | moderator সব accept      ║
// ║  ✅ FIX 3: Tools — PUBLIC READ (অন্য browser-এ দেখা যাবে)      ║
// ║  ✅ FIX 4: Subcategory write — authenticated admin পারবে        ║
// ║  ✅ FIX 5: No syntax errors                                      ║
// ╚══════════════════════════════════════════════════════════════════╝

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin check: email/uid OR admins collection ───────────────
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'mrbanglagggaming@gmail.com' ||
        request.auth.uid == 'E97OGEv5ZJFbHaoojCnFe25GSeY1' ||
        (
          exists(/databases/$(database)/documents/autoscrip_admins/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/autoscrip_admins/$(request.auth.uid)).data.role in
            ['admin', 'super_admin', 'moderator', 'content_manager'] &&
          get(/databases/$(database)/documents/autoscrip_admins/$(request.auth.uid)).data.active != false
        )
      );
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── autoscrip_tools ── PUBLIC READ ✅ ─────────────────────────
    // ✅ FIX: allow read: if true — যে কেউ পড়তে পারবে (অন্য browser-এও)
    match /autoscrip_tools/{toolId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isAuthenticated() &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['views', 'downloads', 'likes']));
      allow delete: if isAdmin();
    }

    // ── autoscrip_users ───────────────────────────────────────────
    match /autoscrip_users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── autoscrip_admins ──────────────────────────────────────────
    match /autoscrip_admins/{adminId} {
      allow read:   if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin() && request.auth.uid != adminId;
    }

    // ── autoscrip_categories ── PUBLIC READ ───────────────────────
    match /autoscrip_categories/{catId} {
      allow read:   if true;
      allow write:  if isAdmin();
      allow delete: if isAdmin();
    }

    // ── autoscrip_requests ────────────────────────────────────────
    match /autoscrip_requests/{reqId} {
      allow create: if isAuthenticated();
      allow read:   if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── autoscrip_notifications ───────────────────────────────────
    match /autoscrip_notifications/{notifId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
      allow delete: if isAdmin();
    }

    // ── autoscrip_comments ── PUBLIC READ ─────────────────────────
    match /autoscrip_comments/{commentId} {
      allow read:   if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    // ── autoscrip_config ── PUBLIC READ ───────────────────────────
    match /autoscrip_config/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── autoscrip_youtube ── PUBLIC READ ──────────────────────────
    match /autoscrip_youtube/{docId} {
      allow read:   if true;
      allow write:  if isAdmin();
      allow delete: if isAdmin();
    }

    // ── autoscrip_subscribers ─────────────────────────────────────
    match /autoscrip_subscribers/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── autoscrip_activity ────────────────────────────────────────
    match /autoscrip_activity/{docId} {
      allow read, write: if isAdmin();
      allow delete:      if isAdmin();
    }

    // ── autoscrip_chat ────────────────────────────────────────────
    match /autoscrip_chat/{msgId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.senderUid == request.auth.uid);
    }

    // ── autoscrip_posts ── PUBLIC READ ────────────────────────────
    match /autoscrip_posts/{postId} {
      allow read:   if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid);
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    // ── autoscrip_scripts ─────────────────────────────────────────
    match /autoscrip_scripts/{scriptId} {
      allow read:   if isAdmin() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid) ||
        resource.data.public == true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    // ── autoscrip_versions ────────────────────────────────────────
    match /autoscrip_versions/{verId} {
      allow read, write: if isAdmin();
    }

    // ── DEFAULT fallback ──────────────────────────────────────────
    match /{collection}/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
